#!/bin/bash

set -e

DOTFILES_DIR="$HOME/dotfiles"
BACKUP_DIR="$HOME/dotfiles_backup/$(date +%Y%m%d_%H%M%S)"

echo "Creating backup directory at $BACKUP_DIR"
mkdir -p "$BACKUP_DIR"
mkdir -p "$HOME/.config"

backup_and_link() {
    local src="$DOTFILES_DIR/$1"
    local dest="$HOME/$2"

    # If file exists and is not a symlink, back it up
    if [ -e "$dest" ] && [ ! -L "$dest" ]; then
        echo "Backing up $dest -> $BACKUP_DIR"
        mv "$dest" "$BACKUP_DIR/"
    fi

    # Create symlink
    echo "Linking $src -> $dest"
    ln -sf "$src" "$dest"
}

backup_and_link "bashrc" ".bashrc"
backup_and_link "vimrc" ".vimrc"
backup_and_link "inputrc" ".inputrc"
backup_and_link "tmux.conf" ".tmux.conf"

# Special case for .config
backup_and_link "starship.toml" ".config/starship.toml"

echo "Dotfiles linked successfully!"
echo "Backup stored in: $BACKUP_DIR"
